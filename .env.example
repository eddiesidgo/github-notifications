# GitHub OAuth App credentials
# Create an OAuth App at: https://github.com/settings/developers
# Authorization callback URL must match GITHUB_REDIRECT_URI below.

GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here

# Must match the OAuth App "Authorization callback URL"
GITHUB_REDIRECT_URI=http://127.0.0.1:42813/callback
OAUTH_CALLBACK_PORT=42813

# Push polling interval (milliseconds). Used by config.monitor.getPollIntervalMs().
# Override that function in config/index.js for adaptive intervals.
POLL_INTERVAL_MS=60000

# --- Auto-updates (GitHub Releases, gratis en repos públicos) ---
# Repo donde electron-builder publica el instalador y latest.yml.
# Debe existir en GitHub antes de `npm run dist` / `npm run release`.
GH_PUBLISH_OWNER=eddiesidgo
GH_PUBLISH_REPO=github-notifications

# Solo para `npm run release` (subir el instalador a Releases).
# Classic PAT con scope `repo`, o fine-grained con Contents: Read and write.
# No hace falta para desarrollo ni para `npm start`.
# GH_TOKEN=ghp_xxxxxxxx
