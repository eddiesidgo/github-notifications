{
  "name": "git-push-notifier",
  "version": "1.1.1",
  "description": "Desktop app for Windows that notifies the team when new pushes land on monitored GitHub repositories",
  "main": "main/main.js",
  "author": "GitPushNotifier",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/${env.GH_PUBLISH_OWNER}/${env.GH_PUBLISH_REPO}.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "node scripts/build-win.js",
    "release": "node scripts/publish-release.js",
    "postinstall": "electron-builder install-app-deps && node scripts/set-electron-icon.js",
    "set-icon": "node scripts/set-electron-icon.js"
  },
  "build": {
    "appId": "com.gitpushnotifier.app",
    "productName": "GitPushNotifier",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "icon": "build/icon.png",
    "afterPack": "./scripts/after-pack.js",
    "files": [
      "main/**/*",
      "renderer/**/*",
      "services/**/*",
      "config/**/*",
      "storage/**/*",
      "notifications/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "${env.GH_PUBLISH_OWNER}",
        "repo": "${env.GH_PUBLISH_REPO}",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@develar/rcedit": "^0.5.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  }
}
